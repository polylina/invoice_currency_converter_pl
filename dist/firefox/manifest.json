{
  "manifest_version": 3,
  "name": "Invoice Currency Converter PL",
  "version": "0.0.3",
  "description": "Convert USD/EUR to PLN using NBP exchange rates. Shows converted amount, conversion note and the NBP table reference.",
  "permissions": ["activeTab"],
  "browser_specific_settings": {
    "gecko": {
      "id": "invoice-currency-converter-pl@extension",
      "strict_min_version": "120.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "action": {
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_title": "Currency Converter PL"
  },
  "background": {
    "page": "background.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["sidebar.html", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
